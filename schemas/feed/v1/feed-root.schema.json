{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Yeah2333/physical-ai-arxiv-feed/schemas/feed/v1/feed-root.schema.json",
  "title": "Robotics arXiv Feed root v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "feed_root_schema_version", "feed_id", "scopes"],
  "properties": {
    "contract_version": {"const": "1.0"},
    "feed_root_schema_version": {"const": "1.0"},
    "feed_id": {"const": "physical-ai-arxiv-facts-v1"},
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scope_id", "index_path", "index_sha256"],
        "properties": {
          "scope_id": {"type": "string", "minLength": 1},
          "index_path": {"type": "string", "minLength": 1},
          "index_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
        }
      }
    }
  }
}
